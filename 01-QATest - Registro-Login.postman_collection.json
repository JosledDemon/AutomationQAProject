    {
      "name": "login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 1. Obtener la respuesta en formato JSON\r",
              "const response = pm.response.json();\r",
              "\r",
              "// 2. Extraer el token. Ajusta 'token' al nombre exacto que use tu API\r",
              "// Si tu respuesta es { \"token\": \"...\" }, usa response.token\r",
              "const token = response.token; \r",
              "\r",
              "if (token) {\r",
              "    // 3. Guardar el token en la variable de entorno que definiste\r",
              "    pm.environment.set(\"token_actual\", token);\r",
              "    console.log(\"¡Token guardado con éxito!\");\r",
              "} else {\r",
              "    console.warn(\"No se encontró el campo 'token' en la respuesta.\");\r",
              "}\r",
              "\r",
              "//------------------------------------------------------------------------\r",
              "pm.test(\"Consulta exitosa\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"El cuerpo de respuesta no está vacío\", function () {\r",
              "    pm.response.to.be.withBody;\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
